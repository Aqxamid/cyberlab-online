# ─────────────────────────────────────────────
# CyberLab Environment Variables
# ─────────────────────────────────────────────

# JWT Secret — use a long random string in production
JWT_SECRET=cyberlab_super_secret_change_me_in_production_min32chars

# ── Supabase (replaces local PostgreSQL) ──────
# Find these in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Frontend API URL (used at runtime by config.js)
# For Docker: use your host/domain. For local dev: leave as default.
API_URL=http://localhost:4000
IDOR_URL=http://localhost:5000
